@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set_and_check(STEAMWORKS_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set_and_check(STEAMWORKS_LIB_DIR "@PACKAGE_CMAKE_INSTALL_LIBDIR@")
if(WIN32)
    set_and_check(STEAMWORKS_BIN_DIR "@PACKAGE_CMAKE_INSTALL_BINDIR@")
endif()

if(NOT TARGET Steamworks::API)
    add_library(Steamworks::API SHARED IMPORTED)
    
    set_target_properties(Steamworks::API PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${STEAMWORKS_INCLUDE_DIR}"
    )
    
    if(WIN32)
        if(CMAKE_SIZEOF_VOID_P EQUAL 8)
            set_target_properties(Steamworks::API PROPERTIES
                IMPORTED_LOCATION "${STEAMWORKS_BIN_DIR}/steam_api64.dll"
                IMPORTED_IMPLIB "${STEAMWORKS_LIB_DIR}/steam_api64.lib"
            )
        else()
            set_target_properties(Steamworks::API PROPERTIES
                IMPORTED_LOCATION "${STEAMWORKS_BIN_DIR}/steam_api.dll"
                IMPORTED_IMPLIB "${STEAMWORKS_LIB_DIR}/steam_api.lib"
            )
        endif()
    elseif(APPLE)
        set_target_properties(Steamworks::API PROPERTIES
            IMPORTED_LOCATION "${STEAMWORKS_LIB_DIR}/libsteam_api.dylib"
        )
    else()
        set_target_properties(Steamworks::API PROPERTIES
            IMPORTED_LOCATION "${STEAMWORKS_LIB_DIR}/libsteam_api.so"
        )
    endif()
endif()

if(NOT TARGET Steamworks::EncryptedAppTicket)
    add_library(Steamworks::EncryptedAppTicket SHARED IMPORTED)
    
    set_target_properties(Steamworks::EncryptedAppTicket PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${STEAMWORKS_INCLUDE_DIR}"
    )
    
    if(WIN32)
        if(CMAKE_SIZEOF_VOID_P EQUAL 8)
            set_target_properties(Steamworks::EncryptedAppTicket PROPERTIES
                IMPORTED_LOCATION "${STEAMWORKS_BIN_DIR}/sdkencryptedappticket64.dll"
                IMPORTED_IMPLIB "${STEAMWORKS_LIB_DIR}/sdkencryptedappticket64.lib"
            )
        else()
            set_target_properties(Steamworks::EncryptedAppTicket PROPERTIES
                IMPORTED_LOCATION "${STEAMWORKS_BIN_DIR}/sdkencryptedappticket.dll"
                IMPORTED_IMPLIB "${STEAMWORKS_LIB_DIR}/sdkencryptedappticket.lib"
            )
        endif()
    elseif(APPLE)
        set_target_properties(Steamworks::EncryptedAppTicket PROPERTIES
            IMPORTED_LOCATION "${STEAMWORKS_LIB_DIR}/libsdkencryptedappticket.dylib"
        )
    else()
        set_target_properties(Steamworks::EncryptedAppTicket PROPERTIES
            IMPORTED_LOCATION "${STEAMWORKS_LIB_DIR}/libsdkencryptedappticket.so"
        )
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/SteamworksSDKHelpers.cmake")

set(_sw_runtime_files "")
foreach(_sw_target Steamworks::API Steamworks::EncryptedAppTicket)
    if(TARGET ${_sw_target})
        get_target_property(_sw_loc ${_sw_target} IMPORTED_LOCATION)
        if(_sw_loc)
            list(APPEND _sw_runtime_files "${_sw_loc}")
        endif()
    endif()
endforeach()
_steamworks_auto_copy_runtime(${_sw_runtime_files})

check_required_components(SteamworksSDK)
